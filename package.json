{
  "name": "@factorialco/welcome",
  "version": "1.0.0",
  "description": "Interactive terminal wizard for Factorial developer environment setup",
  "type": "module",
  "main": "src/index.tsx",
  "bin": {
    "factorial-welcome": "./bin/welcome.mjs"
  },
  "scripts": {
    "start": "tsx src/index.tsx",
    "build": "tsc",
    "dev": "tsx watch src/index.tsx",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then lefthook install; fi"
  },
  "keywords": [
    "factorial",
    "onboarding",
    "developer",
    "setup",
    "cli",
    "ink",
    "tui"
  ],
  "author": "Factorial <dev@factorial.co>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/factorialco/welcome.git"
  },
  "homepage": "https://github.com/factorialco/welcome#readme",
  "bugs": {
    "url": "https://github.com/factorialco/welcome/issues"
  },
  "files": [
    "src",
    "bin",
    "tsconfig.json"
  ],
  "dependencies": {
    "ink": "^6.8.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.0.0",
    "globals": "^17.6.0",
    "lefthook": "^2.1.9",
    "oxfmt": "0.28.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1"
  }
}
